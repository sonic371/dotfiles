# Essentials
XF86AudioMute
	pactl set-sink-mute @DEFAULT_SINK@ toggle 2>/dev/null && kill -42 $(pidof dwmblocks)

XF86AudioLowerVolume
	pactl set-sink-volume @DEFAULT_SINK@ -5% 2>/dev/null && kill -42 $(pidof dwmblocks)

XF86AudioRaiseVolume
	pactl set-sink-volume @DEFAULT_SINK@ +5% 2>/dev/null && kill -42 $(pidof dwmblocks)

XF86AudioMicMute
	pactl set-source-mute @DEFAULT_SOURCE@ toggle && kill -40 $(pidof dwmblocks)

XF86MonBrightnessDown
	brightnessctl s 10%- >/dev/null && kill -35 $(pidof dwmblocks)

XF86MonBrightnessUp
	brightnessctl s +10% >/dev/null && kill -35 $(pidof dwmblocks)

# Screenshot functions
@Print
	maim -s | tee ~/Pictures/screenshots/$(date +%Y-%m-%d_%H-%M-%S).png | xclip -selection clipboard -t image/png

# Dmenu
super + space
	dmenu_run_cus -fn 'Px437 DOS/V re. JPN30:size=14' -nb "#000000" -nf "#ffffff" -sb "#ffffff" -sf "#000000" -l 10 -h 30

# Exec define script
super + d
	~/.config/scripts/dmenu_define

