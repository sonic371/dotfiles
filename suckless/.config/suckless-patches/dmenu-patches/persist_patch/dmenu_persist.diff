diff --git a/dmenu.1 b/dmenu.1
index ed0e442..b03dae1 100644
--- a/dmenu.1
+++ b/dmenu.1
@@ -4,6 +4,7 @@ dmenu \- dynamic menu
 .SH SYNOPSIS
 .B dmenu
 .RB [ \-bfiv ]
+.RB [ \-persist ]
 .RB [ \-l
 .IR lines ]
 .RB [ \-m
@@ -51,6 +52,9 @@ is faster, but will lock up X until stdin reaches end\-of\-file.
 .B \-i
 dmenu matches menu items case insensitively.
 .TP
+.B \-persist
+dmenu does not exit when an item is selected with Return.
+.TP
 .BI \-l " lines"
 dmenu lists items vertically, with the given number of lines.
 .TP
