# Model B1: Click navigation
XF86AudioPrev
	xdotool click --repeat 3 4

XF86AudioNext
	xdotool click --repeat 3 5

XF86AudioPlay
	playerctl play-pause

XF86Back
	xdotool key ctrl+plus

XF86HomePage
	xdotool key ctrl+minus

XF86Mail
