! ============================================
! XTerm Configuration - Enhanced Classic Feel
! ============================================
XTerm*faceName: Px437 DOS/V re. JPN24:pixelsize=24:antialias=false

! === COLOR THEME ===
XTerm*foreground: white
XTerm*background: black

! === SELECTION & CLIPBOARD ===
! Use CLIPBOARD for selections (not just PRIMARY)
XTerm*vt100.selectToClipboard: true

! === KEY BINDINGS ===
XTerm*vt100.translations: #override \
    <BtnUp>: select-end(PRIMARY, CLIPBOARD) \n\
    Ctrl Shift <Key>C: copy-selection(CLIPBOARD) \n\
    Ctrl Shift <Key>V: insert-selection(CLIPBOARD)


*.font: Px437 DOS/V re. JPN24:pixelsize=24
!*.font: FiraMono Nerd Font:pixelsize=24:style=bold
*.alpha: 0.8

*.background: #000000
*.foreground: #ffffff

*.color0:  #1a1b2f
*.color1:  #ff5c7c
*.color2:  #b4f27a
*.color3:  #ffc45c
*.color4:  #6a9eff
*.color5:  #d474ff
*.color6:  #4bcfff
*.color7:  #c7d6ff

*.color8:  #3b4268
*.color9:  #ff5c7c
*.color10: #b4f27a
*.color11: #ffc45c
*.color12: #6a9eff
*.color13: #d474ff
*.color14: #4bcfff
*.color15: #dee6ff
