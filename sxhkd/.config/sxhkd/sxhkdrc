# Essentials
XF86AudioMute
	~/.config/scripts/sxhkd-toggle-volume.sh

XF86AudioLowerVolume
	~/.config/scripts/sxhkd-volume.sh down

XF86AudioRaiseVolume
	~/.config/scripts/sxhkd-volume.sh up

# Brightness down with notification
XF86MonBrightnessDown
        ~/.config/scripts/sxhkd-brightness.sh down

# Brightness up with notification
XF86MonBrightnessUp
        ~/.config/scripts/sxhkd-brightness.sh up

XF86AudioMicMute
	~/.config/scripts/sxhkd-toggle-mic.sh

# Screenshot functions
@Print
	~/.config/scripts/sxhkd-maim.sh >/dev/null 2>&1

# Dmenu
super + space
	dmenu_run_cus -fn 'Px437 DOS/V re. JPN30:size=14' -nb "#000000" -nf "#ffffff" -sb "#ffffff" -sf "#000000" -l 10 -h 30

# Exec define script
super + d
	~/.config/scripts/dmenu_define.sh

super + w
	~/.config/scripts/record-webcam.sh

super + y
	~/.config/scripts/dmenu_media.sh

super + r
	~/.config/scripts/sxhkd_record.sh

# Thinkpad media keys
XF86Display
	~/.local/bin/tool-redshift-toggle >/dev/null 2>&1

XF86Favorites
	~/.local/bin/tool-middle-buttom-toggle >/dev/null 2>&1

# Model B1: Click navigation
XF86AudioPrev
	xdotool click --repeat 3 4

XF86AudioNext
	xdotool click --repeat 3 5

XF86AudioPlay
	playerctl play-pause

XF86Back
	xdotool key ctrl+plus

XF86HomePage
	xdotool key ctrl+minus

XF86Mail
	~/.config/scripts/sxhkd-volume.sh up

XF86WWW
	~/.config/scripts/sxhkd-volume.sh down
